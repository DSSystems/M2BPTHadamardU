Cell[BoxData[
 RowBox[{
  RowBox[{"Box\[Sigma]", "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SubscriptBox["g", 
        RowBox[{"t", ",", "t"}]], "[", "r", "]"}]], 
     FractionBox["1", 
      SuperscriptBox["\[Epsilon]", "2"]], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"dt", ",", "dt"}]], "\[Sigma]"}]}], "+", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"tmp", "=", 
        RowBox[{
         FractionBox[
          RowBox[{"sqrtDetG", "[", "r", "]"}], 
          RowBox[{
           SubscriptBox["g", 
            RowBox[{"r", ",", "r"}]], "[", "r", "]"}]], " ", 
         SubscriptBox["\[Sigma]", "r"]}]}], "}"}], ",", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"sqrtDetG", "[", "r", "]"}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[PartialD]", "r"], "tmp"}], "+", 
         RowBox[{
          FractionBox["1", "\[Epsilon]"], 
          RowBox[{
           SubscriptBox["\[PartialD]", "dr"], "tmp"}]}]}], ")"}]}]}], 
     "]"}]}]}], ";"}]], "Input",
