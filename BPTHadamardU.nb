    RowBox[{
     SubscriptBox["g", 
      RowBox[{"t", ",", "t"}]], "[", "r", "]"}], "2"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
