Cell[BoxData[{
 RowBox[{"Clear", "@", "\[Sigma]Coef\[Gamma]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
      RowBox[{"0", ",", "0"}], "]"}], "[", "r_", "]"}], "=", "0"}], ";"}], 
