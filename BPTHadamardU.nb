Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Solving", " ", 
     SuperscriptBox[
      OverscriptBox["\[Sigma]", "_"], "i"], 
     SubscriptBox[
      OverscriptBox["\[Sigma]", "_"], "i"]}], "=", 
    RowBox[{"2", 
     OverscriptBox["\[Sigma]", "_"]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"nCurrent", "<", "nMax"}], ",", "\n", 
     RowBox[{
      RowBox[{"nCurrent", "=", 
       RowBox[{"nCurrent", "+", "1"}]}], ";", "\n", 
      RowBox[{"\[Sigma]Extra", "=", "0"}], ";", "\n", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"i", "+", "k"}], ">=", " ", "2"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"i", "+", "k"}], "==", "nCurrent"}]}], ",", 
          RowBox[{"\[Sigma]Extra", "=", 
           RowBox[{"\[Sigma]Extra", "+", 
            RowBox[{
             RowBox[{
              RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
               RowBox[{"i", ",", "k"}], "]"}], "[", "r", "]"}], 
             SuperscriptBox["\[Epsilon]", 
              RowBox[{"i", "+", "k"}]], " ", 
             SuperscriptBox["dt", "i"], " ", 
             SuperscriptBox["dr", "k"]}]}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "nCurrent"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "nCurrent"}], "}"}]}], "]"}], ";", "\n", 
      
      RowBox[{"\[Sigma]Exp", "=", 
       RowBox[{"\[Sigma]Exp", "+", "\[Sigma]Extra"}]}], ";", "\n", 
      RowBox[{"\[Sigma]Sumt", "=", 
       RowBox[{"\[Sigma]Sumt", "+", 
        RowBox[{
         FractionBox["1", "\[Epsilon]"], 
         RowBox[{
          SubscriptBox["\[PartialD]", "dt"], "\[Sigma]Extra"}]}]}]}], ";", 
      "\n", 
      RowBox[{"\[Sigma]Sumr", "=", 
       RowBox[{"\[Sigma]Sumr", "+", 
        RowBox[{
         SubscriptBox["\[PartialD]", "r"], "\[Sigma]Extra"}], "+", 
        RowBox[{
         FractionBox["1", "\[Epsilon]"], 
         RowBox[{
          SubscriptBox["\[PartialD]", "dr"], "\[Sigma]Extra"}]}]}]}], ";", 
      "\n", 
      RowBox[{"\[Sigma]Eqn", "=", 
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           FractionBox["1", 
            RowBox[{
             SubscriptBox["g", 
              RowBox[{"t", ",", "t"}]], "[", "r", "]"}]], " ", 
           RowBox[{"Series", "[", 
            RowBox[{
             SuperscriptBox["\[Sigma]Sumt", "2"], ",", 
             RowBox[{"{", 
              RowBox[{"\[Epsilon]", ",", "0", ",", "nMax"}], "}"}]}], "]"}]}],
           "+", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             SubscriptBox["g", 
              RowBox[{"r", ",", "r"}]], "[", "r", "]"}]], " ", 
           RowBox[{"Series", "[", 
            RowBox[{
             SuperscriptBox["\[Sigma]Sumr", "2"], ",", 
             RowBox[{"{", 
              RowBox[{"\[Epsilon]", ",", "0", ",", "nMax"}], "}"}]}], "]"}]}],
           "-", 
          RowBox[{"2", " ", "\[Sigma]Exp"}]}], ",", "\[Epsilon]", ",", 
         "nCurrent"}], "]"}]}], ";", "\n", 
      RowBox[{"Print", "[", 
       RowBox[{"nCurrent", ",", "\"\<\\t\>\"", ",", 
        RowBox[{
         RowBox[{"Timing", "[", 
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"tmp", "=", 
              RowBox[{
               RowBox[{
                RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"nCurrent", "-", "i"}]}], "]"}], "[", "r", "]"}], "/.", 
               RowBox[{
                RowBox[{"Solve", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Coefficient", "[", 
                    RowBox[{"\[Sigma]Eqn", ",", 
                    RowBox[{
                    SuperscriptBox["dt", "i"], " ", 
                    SuperscriptBox["dr", 
                    RowBox[{"nCurrent", "-", "i"}]]}]}], "]"}], "==", "0"}], 
                  ",", 
                  RowBox[{
                   RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
                    RowBox[{"i", ",", 
                    RowBox[{"nCurrent", "-", "i"}]}], "]"}], "[", "r", 
                   "]"}]}], "]"}], "[", 
                RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
                RowBox[{"i", ",", 
                 RowBox[{"nCurrent", "-", "i"}]}], "]"}], "[", "r_", "]"}], 
              "=", 
              RowBox[{"Simplify", "[", "tmp", "]"}]}]}], "\n", ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "0", ",", "nCurrent", ",", "2"}], "}"}]}], 
           "]"}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<\\t\>\"", ",", 
        RowBox[{"Floor", "[", 
         RowBox[{
          RowBox[{"MemoryInUse", "[", "]"}], "/", "1024"}], "]"}]}], "]"}], 
      ";"}]}], "]"}], ";"}]}]], "Input",
