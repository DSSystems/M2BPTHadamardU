Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Solving", " ", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", 
         SuperscriptBox[
          OverscriptBox["\[Sigma]", "_"], "i"], 
         RowBox[{
          SubscriptBox["\[Del]", "i"], " ", 
          RowBox[{"+", " ", 
           RowBox[{"\[Square]", 
            OverscriptBox["\[Sigma]", "_"]}]}]}]}], " ", "-", " ", "2", " ", 
        "+", " ", 
        RowBox[{"2", " ", "s", " ", 
         SuperscriptBox["a", "i"], 
         SubscriptBox[
          OverscriptBox["\[Sigma]", "_"], "i"]}]}], ")"}], "s"], 
     OverscriptBox["U", "_"]}], "=", "0"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sUNMax", "=", 
     RowBox[{"nMax", "-", "2"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"order", " ", "for", " ", 
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      OverscriptBox["U", "_"]}]}], " ", "*)"}], "\n", 
   RowBox[{"Clear", "[", "sUCoef", "]"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"sUCoef", "[", 
        RowBox[{"i_", ",", "_"}], "]"}], "[", "r_", "]"}], "/;", 
      RowBox[{"i", ">", "sUNMax"}]}], "=", "0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"sUCoef", "[", 
       RowBox[{"0", ",", "0"}], "]"}], "[", "r_", "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"at", "=", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["r", 
        RowBox[{"f", "[", "r", "]"}]]}], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        FractionBox[
         RowBox[{"3", "M"}], "r"]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ar", "=", 
     RowBox[{"r", "-", "M"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sUExp", "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"U0Sum", "=", "0"}], "}"}], ",", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"i", "+", "k"}], ">=", "0"}], " ", "&&", " ", 
             RowBox[{
              RowBox[{"i", "+", "k"}], "<=", "sUNMax"}]}], ",", 
            RowBox[{"U0Sum", "=", 
             RowBox[{"U0Sum", "+", 
              RowBox[{
               RowBox[{
                RowBox[{"sUCoef", "[", 
                 RowBox[{"i", ",", "k"}], "]"}], "[", "r", "]"}], 
               SuperscriptBox["\[Epsilon]", 
                RowBox[{"i", "+", "k"}]], " ", 
               SuperscriptBox["dt", "i"], " ", 
               SuperscriptBox["dr", "k"]}]}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "sUNMax"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", "sUNMax"}], "}"}]}], "]"}], ";", 
        "U0Sum"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"Clear", "@", "sUEqns"}], "\n", 
   RowBox[{
    RowBox[{"sUEqns", "=", 
     RowBox[{"CoefficientList", "[", "\n", 
      RowBox[{
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{
           SubscriptBox["g", 
            RowBox[{"t", ",", "t"}]], "[", "r", "]"}]], " ", 
         RowBox[{"Series", "[", 
          RowBox[{
           RowBox[{
            FractionBox["1", "\[Epsilon]"], 
            SubscriptBox["\[Sigma]", "t"], 
            RowBox[{
             SubscriptBox["\[PartialD]", "dt"], "sUExp"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Epsilon]", ",", "0", ",", "sUNMax"}], "}"}]}], "]"}]}],
         "\n", "+", 
        RowBox[{
         FractionBox["1", 
          RowBox[{
           SubscriptBox["g", 
            RowBox[{"r", ",", "r"}]], "[", "r", "]"}]], 
         RowBox[{"Series", "[", 
          RowBox[{
           RowBox[{
            SubscriptBox["\[Sigma]", "r"], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               SubscriptBox["\[PartialD]", "r"], "sUExp"}], "+", 
              RowBox[{
               FractionBox["1", "\[Epsilon]"], 
               RowBox[{
                SubscriptBox["\[PartialD]", "dr"], "sUExp"}]}]}], ")"}]}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"\[Epsilon]", ",", "0", ",", "sUNMax"}], "}"}]}], "]"}]}],
         "\n", "+", 
        RowBox[{
         FractionBox["1", "2"], 
         RowBox[{"Series", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Box\[Sigma]", "-", "2", " ", "+", " ", 
              RowBox[{"2", "s", " ", "at", " ", 
               SubscriptBox["\[Sigma]", "t"]}], " ", "+", " ", 
              RowBox[{"2", " ", "s", " ", "ar", " ", 
               SubscriptBox["\[Sigma]", "r"]}]}], ")"}], "sUExp"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Epsilon]", ",", "0", ",", "sUNMax"}], "}"}]}], 
          "]"}]}]}], ",", "\n", "\[Epsilon]"}], "\n", "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.985255979985237*^9, 3.9852562126346617`*^9}, {
