Cell[TextData[{
 "This notebook is based on the supplemental material provided in PRD 100, \
104037 (2019). Besides the calculation of Synge\[CloseCurlyQuote]s world \
function ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Sigma]", "_"], TraditionalForm]],ExpressionUUID->
  "fa85cc9b-7cd2-4340-a662-290ff78aca2d"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalM]", "2"], TraditionalForm]],ExpressionUUID->
  "a9905f23-707e-488e-91af-89f0de5249da"],
 ", we also provide a small coordinate expansion for the biscalar ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
    OverscriptBox["U", "_"]}], TraditionalForm]],ExpressionUUID->
  "98f9f43d-183f-41d2-a74f-37ed74d12945"],
 ", which satisfies the transport equation\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", 
        SuperscriptBox[
         OverscriptBox["\[Sigma]", "_"], "i"], 
        RowBox[{
         SubscriptBox["\[Del]", "i"], 
         RowBox[{"\[InvisiblePrefixScriptBase]", " ", 
          RowBox[{"+", " ", 
           RowBox[{"\[Square]", 
            OverscriptBox["\[Sigma]", "_"]}]}]}]}]}], " ", "-", " ", "2", " ",
        "+", " ", 
       RowBox[{"2", "s", " ", 
        SuperscriptBox["a", "i"], 
        SubscriptBox[
         OverscriptBox["\[Sigma]", "_"], "i"]}]}], ")"}], 
     RowBox[{
      SubscriptBox["\[InvisiblePrefixScriptBase]", "s"], 
      OverscriptBox["U", "_"]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"9d55e2d5-61c7-43bb-a9c1-183df81bfd6d"]
}], "Text",
 CellChangeTimes->{{3.985257079850051*^9, 3.9852570899685783`*^9}, {
