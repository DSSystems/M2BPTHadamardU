        FractionBox[
         RowBox[{"\[PartialD]", 
          OverscriptBox["\[Sigma]", "_"]}], 
         RowBox[{"\[PartialD]", "dr"}]], 
        FractionBox[
         RowBox[{"\[DifferentialD]", "r"}], 
         RowBox[{"\[DifferentialD]", "dr"}]]}]}], "=", 
      RowBox[{
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Sigma]", "_"]}], 
        RowBox[{"\[PartialD]", "r"}]], "+", 
