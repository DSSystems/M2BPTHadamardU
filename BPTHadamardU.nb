Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Sigma]Exp", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Sigma]Extra", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nCurrent", "=", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"i", "+", "k"}], ">=", " ", "2"}], " ", "&&", " ", 
       RowBox[{
        RowBox[{"i", "+", "k"}], "<=", "nCurrent"}]}], ",", 
      RowBox[{"\[Sigma]Exp", "=", 
       RowBox[{"\[Sigma]Exp", "+", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Sigma]Coef\[Gamma]", "[", 
           RowBox[{"i", ",", "k"}], "]"}], "[", "r", "]"}], 
         SuperscriptBox["\[Epsilon]", 
          RowBox[{"i", "+", "k"}]], " ", 
         SuperscriptBox["dt", "i"], " ", 
         SuperscriptBox["dr", "k"]}]}]}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "0", ",", "nCurrent"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "0", ",", "nCurrent"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Sigma]Sumt", "=", 
    RowBox[{
     FractionBox["1", "\[Epsilon]"], 
     RowBox[{
      SubscriptBox["\[PartialD]", "dt"], "\[Sigma]Exp"}]}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[Sigma]", "_"], "t"], "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Sigma]", "_"]}], 
        RowBox[{"\[PartialD]", "dt"}]], 
       FractionBox[
        RowBox[{"\[DifferentialD]", "dt"}], 
        RowBox[{"\[DifferentialD]", "t"}]]}], "=", 
      RowBox[{
       FractionBox["1", "\[Epsilon]"], 
       FractionBox[
        RowBox[{"\[PartialD]", 
         OverscriptBox["\[Sigma]", "_"]}], 
        RowBox[{"\[PartialD]", "dt"}]]}]}]}], ",", " ", 
    RowBox[{"the", " ", 
     FractionBox["1", "\[Epsilon]"], " ", "corrects", " ", "the", " ", 
     "order", " ", "in", " ", 
     SubscriptBox[
      OverscriptBox["\[Sigma]", "_"], "t"], " ", 
     RowBox[{"(", 
      RowBox[{
      "differentiation", " ", "reduces", " ", "the", " ", "order", " ", "of", 
       " ", "the", " ", "expansion"}], ")"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Sigma]Sumr", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "r"], "\[Sigma]Exp"}], "+", 
     RowBox[{
      FractionBox["1", "\[Epsilon]"], 
      RowBox[{
       SubscriptBox["\[PartialD]", "dr"], "\[Sigma]Exp"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[Sigma]", "_"], "r"], "=", 
